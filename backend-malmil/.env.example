DATABASE_HOST=localhost
DATABASE_NAME=your_db_name
DATABASE_USERNAME=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_PORT=3306
DATABASE_SYNCHRONIZE=false
DATABASE_DEBUG=false
ENV_CORS=http://localhost:4200
APP_PORT=
WA_NUMBER=6281234567890
INSTAGRAM_URL=https://instagram.com/malmil.id

# Generate Midtrans Server Key & Client Key from Midtrans Dashboard (Settings → Access Keys)
# Production: use real keys, set MIDTRANS_IS_PRODUCTION=true
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-your_server_key_here
MIDTRANS_CLIENT_KEY=SB-Mid-client-your_client_key_here

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# Mail (SMTP) – used for password reset & email verification emails
# Set MAIL_DRIVER=log to only log to console (development)
MAIL_DRIVER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@malmil.id
MAIL_FROM_NAME=Malmil

# App URL used in email links (password reset, verification)
APP_URL=http://localhost:4200

# Google OAuth – get credentials from Google Cloud Console (APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
BACKEND_URL=http://localhost:3007
FRONTEND_URL=http://localhost:4200
