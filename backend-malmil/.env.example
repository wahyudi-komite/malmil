# DATABASE_PORT is the NestJS HTTP server port (misleading name, used in main.ts)
DATABASE_HOST=localhost
DATABASE_NAME=your_db_name
DATABASE_USERNAME=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_PORT=3010
DATABASE_SYNCHRONIZE=false
DATABASE_DEBUG=false
ENV_CORS=http://localhost:4200
APP_PORT=
WA_NUMBER=6281234567890
INSTAGRAM_URL=https://instagram.com/malmil.id

# Generate Midtrans Server Key & Client Key from Midtrans Dashboard (Settings → Access Keys)
# Production: use real keys, set MIDTRANS_IS_PRODUCTION=true
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-your_server_key_here
MIDTRANS_CLIENT_KEY=SB-Mid-client-your_client_key_here

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string
