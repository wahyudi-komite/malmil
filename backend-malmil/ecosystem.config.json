{
  "apps": [
    {
      "name": "malmil-api",
      "script": "dist/main.js",
      "cwd": "./backend-malmil",
      "instances": 2,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production"
      },
      "env_file": ".env",
      "max_memory_restart": "500M",
      "error_file": "logs/pm2/err.log",
      "out_file": "logs/pm2/out.log",
      "merge_logs": true,
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "watch": false,
      "kill_timeout": 5000,
      "listen_timeout": 3000
    }
  ]
}
